# QuantAgent v3.0 — Environment Variables Template
# Copy this to `.env` and fill in your API keys.
# The backend auto-loads this file via python-dotenv.

# ── External API Keys ─────────────────────────────────────────────────────────

# Federal Reserve Economic Data (free registration at fred.stlouisfed.org)
FRED_API_KEY=20c5e8383a5ef5bc64e5e756829d4f84

# NewsAPI (free tier: 100 requests/day at newsapi.org)
NEWS_API_KEY=pub_a491c2072cd0478288b188b292c9ccc1

# Reddit API (create at reddit.com/prefs/apps — "script" type, read-only)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# ── Model Storage ─────────────────────────────────────────────────────────────

# Where trained RL models are saved (default: ./models/)
MODEL_SAVE_DIR=./models

# Where FinBERT weights are cached (first run downloads ~440MB)
FINBERT_CACHE_DIR=./models/finbert

# ── Paper Portfolio ───────────────────────────────────────────────────────────

PAPER_PORTFOLIO_PATH=./data/paper_portfolio.json

# ── Deployment (optional) ─────────────────────────────────────────────────────

# Set in Railway/Render for CORS origin whitelisting
VERCEL_FRONTEND_URL=https://your-app.vercel.app

# Port (Railway injects this automatically)
# PORT=8000
